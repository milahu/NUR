---
 pkgs/development/tools/language-servers/nixd/default.nix | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/pkgs/development/tools/language-servers/nixd/default.nix b/pkgs/development/tools/language-servers/nixd/default.nix
index 00b99efdf3c20c829f2339017cda33184345241d..f1b9faef3ff955b1b12c6608cd002be793970cca 100644
