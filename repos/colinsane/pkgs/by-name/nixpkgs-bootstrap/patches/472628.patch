From c72b1c1aabda96757fa0532411b02c6e2b968bac Mon Sep 17 00:00:00 2001
From: Colin <colin@uninsane.org>
Date: Sat, 20 Dec 2025 07:22:18 +0000
Subject: [PATCH] Revert "wrapGAppsNoGuiHook: fix cross usage"

This reverts commit 08b7d845bb617d9add7ba1b8a102cc2b8777ab8a.

The referenced commit causes `bin/$p` and `bin/.$p-wrapped` to be built
for mismatched architecture (build platform and host platform, respectively)
for at least the following packages:
- `pkgsCross.aarch64-multiplatform.dialect`
- `pkgsCross.aarch64-multiplatform.networkd-dispatcher`
---
 pkgs/top-level/all-packages.nix | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pkgs/top-level/all-packages.nix b/pkgs/top-level/all-packages.nix
index d1ad51ba358c3b0ba09e866eb736e66a019272a7..3016837a78821eeb2b0aed05433c1f002a84362b 100644
--- a/pkgs/top-level/all-packages.nix
+++ b/pkgs/top-level/all-packages.nix
@@ -918,7 +918,7 @@ with pkgs;
   };
 
   wrapGAppsNoGuiHook = callPackage ../build-support/setup-hooks/wrap-gapps-hook {
-    makeWrapper = buildPackages.makeBinaryWrapper;
+    makeWrapper = makeBinaryWrapper;
   };
 
   separateDebugInfo = makeSetupHook {
